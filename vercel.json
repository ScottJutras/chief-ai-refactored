{
  "version": 2,
  "functions": {
    "api/webhook.js": {
      "memory": 2048,
      "maxDuration": 15,
      "excludeFiles": "{public/**,dashboard/**,parse/**,deep-dive/**,api/index.js,node_modules/exceljs/**}"
    },
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/ping.js": {
      "memory": 256,
      "maxDuration": 5
    },
    "api/cron/refresh_docs.js": {
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "{scripts/rag_loader.js,docs/howto/**}"
    },
    "api/cron/cleanup_pending.js": {
      "memory": 512,
      "maxDuration": 10
    },
    "api/cron/overhead_reminders.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/cron/weekly_digest.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/cron/margin_monitor.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/cron/daily_job_summary.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/cron/anomaly_detector.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/cron/tax_readiness.js": {
      "memory": 512,
      "maxDuration": 60
    }
  },
  "routes": [
    { "handle": "filesystem" },

    { "src": "^/favicon\\.ico$", "dest": "/favicon.ico" },
    { "src": "^/favicon\\.png$", "dest": "/favicon.png" },

    { "src": "^/api/cron/refresh_docs$", "dest": "/api/cron/refresh_docs.js" },
    { "src": "^/api/cron/cleanup-pending$",      "dest": "/api/cron/cleanup_pending.js" },
    { "src": "^/api/cron/overhead-reminders$",   "dest": "/api/cron/overhead_reminders.js" },
    { "src": "^/api/cron/weekly-digest$",         "dest": "/api/cron/weekly_digest.js" },
    { "src": "^/api/cron/margin-monitor$",        "dest": "/api/cron/margin_monitor.js" },
    { "src": "^/api/cron/daily-job-summary$",     "dest": "/api/cron/daily_job_summary.js" },
    { "src": "^/api/cron/anomaly-detector$",      "dest": "/api/cron/anomaly_detector.js" },
    { "src": "^/api/cron/tax-readiness$",         "dest": "/api/cron/tax_readiness.js" },

    { "src": "^/api/webhook/reminders/cron/(.*)$", "dest": "/api/webhook.js" },
    { "src": "^/api/webhook$", "dest": "/api/webhook.js" },
    { "src": "^/webhook$", "dest": "/api/webhook.js" },

    { "src": "^/api/ping$", "dest": "/api/ping.js" },

    
    { "src": "^/api/receipts/(.*)$", "dest": "/api/index.js" },

    { "src": "^/(.*)$", "dest": "/api/index.js" }
  ],
  "crons": [
    { "path": "/api/cron/refresh_docs", "schedule": "0 3 * * 1" },
    { "path": "/api/cron/cleanup-pending",    "schedule": "5 3 * * 1" },
    { "path": "/api/cron/overhead-reminders", "schedule": "0 8 * * *" },
    { "path": "/api/cron/weekly-digest",      "schedule": "0 16 * * 5" },
    { "path": "/api/cron/margin-monitor",     "schedule": "0 */6 * * *" },
    { "path": "/api/cron/daily-job-summary",  "schedule": "0 22 * * *" },
    { "path": "/api/cron/anomaly-detector",   "schedule": "0 */4 * * *" },
    { "path": "/api/cron/tax-readiness",      "schedule": "0 9 1 1,4,7,10 *" }
  ]
}